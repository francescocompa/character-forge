// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SheetMarkup — composite lines (snapshots) > renders a Mind Sliver-style cantrip line 1`] = `"<span class="damage-text" style="--chip-fg:var(--dmg-psychic)"><span class="damage-text__dice">1d6</span><span class="damage-text__type">psychic</span></span> &amp; <span class="chip save-badge" style="--chip-fg:var(--ability-int)">INT<span class="save-badge__dc">DC 13</span></span> — on a fail, target subtracts <span class="damage-text" style="--chip-fg:var(--dmg-neutral)"><span class="damage-text__dice">1d4</span></span> from its next save"`;

exports[`SheetMarkup — composite lines (snapshots) > renders a mixed-recovery resource line 1`] = `"Regain <span class="damage-text" style="--chip-fg:var(--dmg-neutral)"><span class="damage-text__dice">1d10+5</span></span> HP. <strong>2</strong> uses per <svg class="recover-icon" style="--chip-fg:var(--recover-lr)" viewBox="0 0 16 16" role="img" aria-label="Long rest" fill="var(--chip-fg)"><path d="M9.5 2a6 6 0 1 0 4.5 9.9A5 5 0 0 1 9.5 2Z"></path></svg>; regain <strong>1</strong> use on a <svg class="recover-icon" style="--chip-fg:var(--recover-sr)" viewBox="0 0 16 16" role="img" aria-label="Short rest" fill="var(--chip-fg)"><circle cx="8" cy="8" r="4"></circle></svg>."`;

exports[`SheetMarkup — composite lines (snapshots) > renders a reflavored feature with a library link 1`] = `"<span class="ref-link">Fey Pact</span>: <span class="chip state-badge state-badge--adv">EDGE</span> on <span class="chip save-badge" style="--chip-fg:var(--ability-wis)">WIS</span> against being <span class="chip condition-chip">charmed</span>"`;
